name: OpenCode PR Assistant

on:
  pull_request:
    types:
      - opened
      - reopened
      - synchronize
      - edited
      - ready_for_review
  pull_request_review_comment:
    types:
      - created
      - edited

permissions:
  contents: write
  issues: write
  pull-requests: write
  checks: read
  statuses: read

jobs:
  opencode-pr:
    name: Run Vinkbot on PR
    runs-on: ubuntu-latest
    timeout-minutes: 360

    env:
      MODEL: "opencode/qwen3.6-plus-free"
      PR_NUMBER: ${{ github.event.pull_request.number || github.event.issue.number }}
      EVENT_NAME: ${{ github.event_name }}
      LATEST_COMMENT: ${{ github.event.comment.body || '' }}

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Install dependencies
        run: |
          set -euo pipefail

          sudo apt-get update -qq
          sudo apt-get install -y curl git jq

      - name: Install OpenCode
        run: |
          set -euo pipefail

          curl -fsSL https://opencode.ai/install | bash
          echo "$HOME/.opencode/bin" >> "$GITHUB_PATH"

      - name: Configure git bot
        run: |
          set -euo pipefail

          git config user.name "Vinkbot"
          git config user.email "272188895+Vinkbot@users.noreply.github.com"

      - name: Read PR context
        id: pr
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          set -euo pipefail

          gh pr view "$PR_NUMBER" \
            --json number,title,body,state,isDraft,url,author,baseRefName,headRefName,headRepository,headRepositoryOwner,comments,reviews,files,commits,reviewDecision,mergeStateStatus,createdAt,updatedAt \
            > /tmp/pr-context.json

          PR_TITLE="$(jq -r '.title // ""' /tmp/pr-context.json)"
          PR_BODY="$(jq -r '.body // ""' /tmp/pr-context.json)"
          PR_URL="$(jq -r '.url // ""' /tmp/pr-context.json)"
          BASE_REF="$(jq -r '.baseRefName // ""' /tmp/pr-context.json)"
          HEAD_REF="$(jq -r '.headRefName // ""' /tmp/pr-context.json)"
          HEAD_REPO="$(jq -r '.headRepository.nameWithOwner // ""' /tmp/pr-context.json)"
          HEAD_OWNER="$(jq -r '.headRepositoryOwner.login // ""' /tmp/pr-context.json)"
          IS_DRAFT="$(jq -r '.isDraft // false' /tmp/pr-context.json)"
          MERGE_STATE="$(jq -r '.mergeStateStatus // ""' /tmp/pr-context.json)"
          CURRENT_REPO="${{ github.repository }}"

          {
            echo "title<<PR_TITLE_EOF"
            echo "$PR_TITLE"
            echo "PR_TITLE_EOF"

            echo "body<<PR_BODY_EOF"
            echo "$PR_BODY"
            echo "PR_BODY_EOF"

            echo "url=$PR_URL"
            echo "base_ref=$BASE_REF"
            echo "head_ref=$HEAD_REF"
            echo "head_repo=$HEAD_REPO"
            echo "head_owner=$HEAD_OWNER"
            echo "is_draft=$IS_DRAFT"
            echo "merge_state=$MERGE_STATE"
            echo "current_repo=$CURRENT_REPO"
          } >> "$GITHUB_OUTPUT"

      - name: Checkout PR branch
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          set -euo pipefail

          gh pr checkout "$PR_NUMBER"

      - name: Save starting commit
        id: before
        run: |
          set -euo pipefail

          BEFORE_SHA="$(git rev-parse HEAD)"
          echo "sha=$BEFORE_SHA" >> "$GITHUB_OUTPUT"

      - name: Build OpenCode prompt
        env:
          PR_TITLE: ${{ steps.pr.outputs.title }}
          PR_BODY: ${{ steps.pr.outputs.body }}
          PR_URL: ${{ steps.pr.outputs.url }}
          BASE_REF: ${{ steps.pr.outputs.base_ref }}
          HEAD_REF: ${{ steps.pr.outputs.head_ref }}
          HEAD_REPO: ${{ steps.pr.outputs.head_repo }}
          CURRENT_REPO: ${{ steps.pr.outputs.current_repo }}
          IS_DRAFT: ${{ steps.pr.outputs.is_draft }}
          MERGE_STATE: ${{ steps.pr.outputs.merge_state }}
        run: |
          set -euo pipefail

          cat > /tmp/opencode-pr-prompt.md <<'PROMPT_EOF'
          You are Vinkbot, an automated GitHub pull request assistant running inside a GitHub Actions workflow.

          You have access to the GitHub CLI through `gh`.

          You can:
          - read pull request details and comments
          - reply to PRs using `gh pr comment`
          - add helpful labels using `gh pr edit`
          - inspect the repository
          - review changed files
          - make small code changes when clearly requested
          - commit changes when needed
          - push commits to the PR branch when allowed
          - merge the PR yourself using `gh pr merge` when it is clearly appropriate

          You must not:
          - treat every comment as a coding request
          - create code changes for a simple ping, test, or status-check comment
          - add a `solved` label by yourself
          - merge draft PRs
          - merge PRs with unclear intent
          - merge PRs when the latest comment is only a ping/test/status check
          - merge PRs if there are obvious unresolved requested changes
          - merge PRs if the PR appears unsafe, broken, or unrelated

          Merge behavior:
          You may merge the PR yourself only when one of these is true:
          - a maintainer explicitly asks you to merge
          - the PR text clearly asks for automatic merge
          - the latest comment clearly says something like "merge this", "ship it", "looks good, merge", or "Vinkbot merge"

          Before merging:
          - Check whether the PR is a draft. Do not merge drafts.
          - Check PR status and merge state using `gh pr view`.
          - If checks are still running, wait only if reasonable, otherwise comment that checks are not ready.
          - If checks failed, do not merge unless a maintainer explicitly says to merge despite failures.
          - If branch protection prevents merging, comment briefly and stop.
          - Prefer squash merge unless the PR clearly asks for another merge method.

          Merge command examples:
          - `gh pr merge "$PR_NUMBER" --squash --delete-branch`
          - If GitHub requires auto-merge and it is appropriate, use `gh pr merge "$PR_NUMBER" --squash --delete-branch --auto`

          After merging:
          - Comment briefly that you merged it.
          - Do not create extra commits after merge.
          - Do not close anything separately.

          Humans still have final responsibility for repository policy, but you may perform the merge when clearly asked and safe.

          Tone:
          - Be friendly
          - Be natural
          - Be short when the user only asks for a simple response
          - Do not sound overly formal
          - Do not write long explanations unless useful

          Simple ping/test behavior:
          If the latest comment is only asking whether you are working, whether you can read the comment, or asking for a simple response, then:
          - reply briefly with `gh pr comment`
          - do not edit files
          - do not commit
          - do not add labels
          - do not merge

          Good example response for a ping:
          "Yes — I'm here and working 🙂"

          For real PR work:
          - Inspect the PR context and repository.
          - If the PR author or maintainer asks for a specific change, make the smallest safe change.
          - If the request is unclear, ask a short friendly question using `gh pr comment`.
          - If you notice an obvious issue, you may comment with a helpful suggestion.
          - If you make code changes, commit them with a clear commit message.
          - If you commit changes, you may push them yourself if possible.
          - Do not create a new PR.
          - If no file changes are needed, do not commit anything.
          - Do not write `opencode-decision.json`; it is not used.

          Important GitHub CLI rules:
          - Use `gh pr comment "$PR_NUMBER" --body "..."`
          - Use `gh pr edit "$PR_NUMBER" --add-label "label-name"` only when genuinely useful.
          - Use `gh pr merge "$PR_NUMBER" --squash --delete-branch` only when merge rules above are satisfied.
          - The environment variable `GH_TOKEN` is available.

          Current event:
          __EVENT_NAME__

          PR number:
          __PR_NUMBER__

          PR title:
          __PR_TITLE__

          PR URL:
          __PR_URL__

          Base branch:
          __BASE_REF__

          Head branch:
          __HEAD_REF__

          Head repository:
          __HEAD_REPO__

          Current repository:
          __CURRENT_REPO__

          Is draft:
          __IS_DRAFT__

          Merge state:
          __MERGE_STATE__

          Latest comment, if this run was triggered by a comment:
          __LATEST_COMMENT__

          PR body:
          __PR_BODY__

          Full PR context as JSON:
          __FULL_PR_CONTEXT__
          PROMPT_EOF

          python3 - <<'PY'
          from pathlib import Path
          import os

          prompt_path = Path("/tmp/opencode-pr-prompt.md")
          prompt = prompt_path.read_text()

          context_path = Path("/tmp/pr-context.json")
          full_context = context_path.read_text() if context_path.exists() else ""

          replacements = {
              "__EVENT_NAME__": os.environ.get("EVENT_NAME", ""),
              "__PR_NUMBER__": os.environ.get("PR_NUMBER", ""),
              "__PR_TITLE__": os.environ.get("PR_TITLE", ""),
              "__PR_URL__": os.environ.get("PR_URL", ""),
              "__BASE_REF__": os.environ.get("BASE_REF", ""),
              "__HEAD_REF__": os.environ.get("HEAD_REF", ""),
              "__HEAD_REPO__": os.environ.get("HEAD_REPO", ""),
              "__CURRENT_REPO__": os.environ.get("CURRENT_REPO", ""),
              "__IS_DRAFT__": os.environ.get("IS_DRAFT", ""),
              "__MERGE_STATE__": os.environ.get("MERGE_STATE", ""),
              "__LATEST_COMMENT__": os.environ.get("LATEST_COMMENT", ""),
              "__PR_BODY__": os.environ.get("PR_BODY", ""),
              "__FULL_PR_CONTEXT__": full_context,
          }

          for key, value in replacements.items():
              prompt = prompt.replace(key, value)

          prompt_path.write_text(prompt)
          PY

      - name: Run OpenCode
        id: opencode_run
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          set -euo pipefail

          opencode run "$(cat /tmp/opencode-pr-prompt.md)" \
            --model "$MODEL" \
            --thinking \
            --dangerously-skip-permissions

      - name: Check PR state after OpenCode
        id: after_pr
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          set -euo pipefail

          gh pr view "$PR_NUMBER" \
            --json state,merged,mergeCommit,url \
            > /tmp/pr-after.json

          PR_STATE="$(jq -r '.state // ""' /tmp/pr-after.json)"
          PR_MERGED="$(jq -r '.merged // false' /tmp/pr-after.json)"

          echo "state=$PR_STATE" >> "$GITHUB_OUTPUT"
          echo "merged=$PR_MERGED" >> "$GITHUB_OUTPUT"

      - name: Stop if PR was merged by agent
        if: steps.after_pr.outputs.merged == 'true'
        run: |
          echo "PR was merged by Vinkbot/OpenCode. No further workflow action needed."

      - name: Check for repository changes
        id: changes
        if: steps.after_pr.outputs.merged != 'true'
        run: |
          set -euo pipefail

          BEFORE_SHA="${{ steps.before.outputs.sha }}"
          CURRENT_SHA="$(git rev-parse HEAD)"

          if [ -n "$(git status --porcelain)" ]; then
            echo "has_changes=true" >> "$GITHUB_OUTPUT"
          elif [ "$CURRENT_SHA" != "$BEFORE_SHA" ]; then
            echo "has_changes=true" >> "$GITHUB_OUTPUT"
          else
            echo "has_changes=false" >> "$GITHUB_OUTPUT"
          fi

      - name: Stop if no files changed
        if: steps.after_pr.outputs.merged != 'true' && steps.changes.outputs.has_changes == 'false'
        run: |
          echo "No repository changes were made. Nothing to push."

      - name: Commit uncommitted changes
        if: steps.after_pr.outputs.merged != 'true' && steps.changes.outputs.has_changes == 'true'
        run: |
          set -euo pipefail

          if [ -n "$(git status --porcelain)" ]; then
            git add -A
            git commit -m "fix(pr #$PR_NUMBER): apply requested update"
          else
            echo "No uncommitted changes. OpenCode may have already committed."
          fi

      - name: Check if PR branch is in this repository
        id: branch_location
        if: steps.after_pr.outputs.merged != 'true' && steps.changes.outputs.has_changes == 'true'
        run: |
          set -euo pipefail

          if [ "${{ steps.pr.outputs.head_repo }}" = "${{ steps.pr.outputs.current_repo }}" ]; then
            echo "same_repo=true" >> "$GITHUB_OUTPUT"
          else
            echo "same_repo=false" >> "$GITHUB_OUTPUT"
          fi

      - name: Push changes to PR branch
        id: push
        if: steps.after_pr.outputs.merged != 'true' && steps.changes.outputs.has_changes == 'true' && steps.branch_location.outputs.same_repo == 'true'
        continue-on-error: true
        run: |
          set -euo pipefail

          HEAD_REF="${{ steps.pr.outputs.head_ref }}"

          if git push origin HEAD:"$HEAD_REF"; then
            echo "push_failed=false" >> "$GITHUB_OUTPUT"
          else
            echo "push_failed=true" >> "$GITHUB_OUTPUT"
          fi

      - name: Comment after successful push
        if: steps.after_pr.outputs.merged != 'true' && steps.changes.outputs.has_changes == 'true' && steps.branch_location.outputs.same_repo == 'true' && steps.push.outputs.push_failed != 'true'
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          gh pr comment "$PR_NUMBER" \
            --body "✅ I pushed a small update to this PR. Please review it when you can."

      - name: Comment if PR branch is from a fork
        if: steps.after_pr.outputs.merged != 'true' && steps.changes.outputs.has_changes == 'true' && steps.branch_location.outputs.same_repo != 'true'
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          SUMMARY="$(git diff --stat "${{ steps.before.outputs.sha }}"..HEAD || true)"

          gh pr comment "$PR_NUMBER" \
            --body "$(cat <<EOF
          I prepared changes locally, but this PR branch is from a fork, so I cannot safely push to it.

          Changes summary:

          \`\`\`
          $SUMMARY
          \`\`\`

          Please apply the changes manually if they look useful.
          EOF
          )"

      - name: Comment if push failed
        if: steps.after_pr.outputs.merged != 'true' && steps.changes.outputs.has_changes == 'true' && steps.branch_location.outputs.same_repo == 'true' && steps.push.outputs.push_failed == 'true'
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          SUMMARY="$(git diff --stat "${{ steps.before.outputs.sha }}"..HEAD || true)"

          gh pr comment "$PR_NUMBER" \
            --body "$(cat <<EOF
          I prepared changes, but I could not push them to the PR branch.

          Changes summary:

          \`\`\`
          $SUMMARY
          \`\`\`

          A human needs to apply or push these changes manually.
          EOF
          )"
