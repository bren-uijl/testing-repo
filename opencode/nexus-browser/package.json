{
  "name": "nexus-browser",
  "version": "1.0.0",
  "description": "A next-generation Chromium-based browser with full Chrome Web Store extension support",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --linux",
    "package": "electron-builder --publish never",
    "installer": "node scripts/create-installer.js"
  },
  "keywords": [
    "browser",
    "chromium",
    "electron",
    "privacy",
    "extensions"
  ],
  "author": "Nexus Browser Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "electron-dl": "^3.5.1",
    "electron-store": "^8.1.0"
  },
  "build": {
    "appId": "com.nexusbrowser.app",
    "productName": "Nexus Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
