{
  "name": "nexus-browser",
  "version": "1.0.0",
  "description": "A next-generation Chromium-based browser with full Chrome Web Store extension support",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux",
    "build:offline": "electron-builder --win --config.nsis.differentialPackage=false --config.nsis.perMachine=true",
    "package": "electron-builder --publish never",
    "build-installer": "node scripts/build-installer.js",
    "installer": "node scripts/create-installer.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/"
  },
  "keywords": [
    "browser",
    "chromium",
    "electron",
    "chrome-extensions",
    "privacy",
    "extensions"
  ],
  "author": "Nexus Browser Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexus-browser/nexus.git"
  },
  "build": {
    "appId": "com.nexusbrowser.app",
    "productName": "Nexus Browser",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json",
      "LICENSE"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.svg",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nexus Browser",
      "installerIcon": "assets/icon.svg",
      "uninstallerIcon": "assets/icon.svg",
      "installerHeaderIcon": "assets/icon.svg",
      "include": "build/installer.nsh",
      "license": "LICENSE",
      "differentialPackage": false
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "assets/icon.svg",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/",
      "category": "Network"
    },
    "publish": null
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "electron-dl": "^3.5.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "jsdom": "^24.0.0"
  }
}
